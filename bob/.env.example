# cp .env.example .env → then fill in your keys

# ─── BRAIN: Creative Ad Agent ─────────────────
ANTHROPIC_API_KEY=
FAL_KEY=

# ─── HANDS: Meta Ads AI Agent ────────────────
FB_ACCESS_TOKEN=
AD_ACCOUNT_ID=
PAGE_ID=
FB_PIXEL_ID=
REPLICATE_API_TOKEN=
LANDING_PAGE_URL=
DAILY_BUDGET_PER_ADSET=5

# ─── MOUTH: Meta Ads Kit ─────────────────────
META_AD_ACCOUNT=

# ─── SLACK: Client Notifications ─────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL=#bob-ads
SLACK_WEBHOOK_URL=

# ─── BOB: Orchestrator ───────────────────────
BOB_DATA_DIR=./data
BOB_LOG_DIR=./logs
BOB_PORT=5000
