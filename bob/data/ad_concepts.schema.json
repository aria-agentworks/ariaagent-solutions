{
  "definitions": {
    "AdConcept": {
      "type": "object",
      "required": ["id", "hook", "headline", "body_copy", "image_prompt", "target_audience"],
      "properties": {
        "id": { "type": "string" },
        "hook_type": { "type": "string", "enum": ["question","bold_claim","pain_point","social_proof","curiosity","fear_of_missing_out"] },
        "hook": { "type": "string" },
        "headline": { "type": "string", "maxLength": 40 },
        "body_copy": { "type": "string", "maxLength": 125 },
        "long_copy": { "type": "string" },
        "image_prompt": { "type": "string" },
        "video_motion_prompt": { "type": "string" },
        "target_audience": { "type": "string" },
        "image_url": { "type": "string" },
        "video_url": { "type": "string" },
        "meta_ad_id": { "type": "string" },
        "meta_adset_id": { "type": "string" },
        "status": { "type": "string", "enum": ["concept","generating","deployed","monitoring","paused","scaled","killed"] }
      }
    }
  }
}
